<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
      body { margin: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: linear-gradient(180deg, #f4f9ff 0%, #e7efff 100%); color: #1a202c; }
      .produtos-container { max-width: 1100px; margin: 40px auto; padding: 24px; background: rgba(255,255,255,0.94); border-radius: 16px; box-shadow: 0 14px 40px rgba(21, 60, 121, 0.12); border: 1px solid rgba(0,0,0,0.05); }
      .produtos-container h1 { margin: 0; font-size: 2rem; letter-spacing: 0.2px; color: #163a72; }
      .produtos-container p { color: #4b5563; margin: 8px 0 14px; }
      .produtos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 18px; margin-top: 18px; }
      .produto-card { background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; padding: 15px 14px; box-shadow: 0 5px 15px rgba(0,0,0,0.06); transition: transform 0.2s ease, box-shadow 0.2s ease; }
      .produto-card:hover { transform: translateY(-3px); box-shadow: 0 10px 22px rgba(0, 0, 0, 0.12); }
      .produto-nome { font-size: 1.15rem; color: #111827; font-weight: 700; margin-bottom: 6px; }
      .produto-descricao { color: #6b7280; margin-bottom: 12px; font-size: 0.93rem; min-height: 42px; }
      .produto-preco { font-size: 1.2rem; color: #059669; font-weight: 700; margin-bottom: 14px; }
      .btn-comprar { background: #2563eb; color: #fff; border: none; border-radius: 10px; padding: 9px 14px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.2s ease; }
      .btn-comprar:hover { background: #1d4ed8; }
    </style>
  </head>
  <body>
    <div class="produtos-container">
      <h1><%= title %></h1>
      <p>Confira nossos produtos disponíveis</p>
      
      <div class="produtos-grid">
        <% produtos.forEach(function(produto) { %>
          <div class="produto-card">
            <div class="produto-nome"><%= produto.nome %></div>
            <div class="produto-descricao">Descrição do <%= produto.nome %> disponível em breve</div>
            <div class="produto-preco">R$ <%= produto.preco.toFixed(2).replace('.', ',') %></div>
            <button class="btn-comprar">Comprar</button>
          </div>
        <% }); %>
      </div>
    </div>
  </body>
</html>