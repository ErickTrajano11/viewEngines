      .horario-item
        .horario-dia Terça
        .horario-tempo 08:00 - 18:00
      .horario-item
        .horario-dia Quarta
        .horario-tempo 08:00 - 18:00
      .horario-item
        .horario-dia Quinta
        .horario-tempo 08:00 - 18:00
      .horario-item
        .horario-dia Sexta
        .horario-tempo 08:00 - 18:00
      .horario-item
        .horario-dia Sábado
        .horario-tempo 09:00 - 13:00
      .horario-item
